---
import MainLayout from "../layouts/MainLayout.astro";

const name = "Daniel Kats";
---

<MainLayout title="Home">

<section class="hero-section position-relative text-white">

  <div class="hero-overlay"></div>

  <div class="container hero-content">

    <div class="row align-items-center justify-content-between">

      <!-- TEXT SIDE -->
      <div class="col-lg-6 text-center text-lg-start hero-text-area"
        data-aos="fade-right">

        <h1 class="fw-bold hero-title">
          Hello, I'm <span class="text-primary">{name}</span>
        </h1>

        <p class="lead mt-3 hero-text">
          Full Stack Developer specializing in modern web development using JavaScript, React, Astro, and Django.
        </p>

        <div class="mt-4 d-flex flex-column flex-sm-row gap-3 justify-content-center justify-content-lg-start">
          <a href="/about" class="btn btn-primary px-4 py-2">About Me</a>
          <a href="/blog" class="btn btn-outline-light px-4 py-2">Read Blog</a>
        </div>

      </div>

      <!-- IMAGE SIDE -->
      <div class="col-lg-6 text-center mt-5 mt-lg-0"
        data-aos="zoom-in">

        <div class="hero-image-wrapper">
          <img src="/assets/img/profile.jpg" alt="author">
        </div>

      </div>

    </div>
  </div>
</section>
<section id="about" class="py-5" data-aos="fade-up">
  <div class="container">

    <div class="row align-items-center">

      <!-- Text -->
      <div class="col-lg-7 text-center text-lg-start mb-4 mb-lg-0"
        data-aos="fade-right">

        <h2 class="display-6 text-primary fw-bold text-uppercase">
          Who am I?
        </h2>

        <p class="mt-3 text-secondary">
          I'm {name}, a Full Stack Developer with experience in building modern web applications using JavaScript, React, Astro, and Django.
        </p>

      </div>

      <!-- Chart -->
      <div class="col-lg-5 text-center"
        data-aos="zoom-in">

        <h5 class="mb-4 text-primary fw-bold text-uppercase">
          
        </h5>

        <div class="chart-container">
          <canvas id="skillsChart"></canvas>
        </div>

      </div>

    </div>
  </div>
</section>

<!-- Services Section -->
<section id="services" class="py-5" data-aos="fade-up">
  <div class="container text-center">

    <h2 class="display-5 text-primary fw-bold text-uppercase"
      data-aos="fade-down">
      Here's what I'm good at
    </h2>

    <p class="mt-2 text-secondary" data-aos="fade-down" data-aos-delay="100">
      These are the services I offer
    </p>

    <div class="row mt-4 g-4">

      <div class="col-md-4" data-aos="zoom-in" data-aos-delay="100">
        <div class="card h-100 text-center border-0 shadow p-4 hover-scale">
          <i class="bi bi-code-slash text-primary mb-3" style="font-size:4rem;"></i>
          <h5 class="text-primary fw-bold text-uppercase">Web Development</h5>
          <p class="text-secondary">
            I build modern, responsive, and scalable websites using HTML, CSS, JavaScript, React, Astro, and Bootstrap.
          </p>
        </div>
      </div>

      <div class="col-md-4" data-aos="zoom-in" data-aos-delay="200">
        <div class="card h-100 text-center border-0 shadow p-4 hover-scale">
          <i class="bi bi-wordpress text-primary mb-3" style="font-size:4rem;"></i>
          <h5 class="text-primary fw-bold text-uppercase">WordPress Development</h5>
          <p class="text-secondary">
            I design and customize WordPress websites with CMS solutions and plugin integration.
          </p>
        </div>
      </div>

      <div class="col-md-4" data-aos="zoom-in" data-aos-delay="300">
        <div class="card h-100 text-center border-0 shadow p-4 hover-scale">
          <i class="bi bi-database-fill text-primary mb-3" style="font-size:4rem;"></i>
          <h5 class="text-primary fw-bold text-uppercase">Backend & API Development</h5>
          <p class="text-secondary">
            I develop secure backend systems and REST APIs using PHP and MySQL.
          </p>
        </div>
      </div>

    </div>
  </div>
</section>

<!-- Portfolio Section -->
<section id="portfolio" class="py-5 " data-aos="fade-up">
  <div class="container text-center">

    <h2 class="display-5 text-primary fw-bold text-uppercase">Check out my Works</h2>
    <p class="text-secondary mt-2">Some of my recent projects</p>

    <div class="row mt-4 g-4">

      <div class="col-md-4" data-aos="fade-up" data-aos-delay="100">
        <a href="http://s-kata.great-site.net/" class="d-block overflow-hidden rounded shadow portfolio-item">
          <img src="/assets/img/skata.png" class="img-fluid" alt="Portfolio project">
        </a>
      </div>

      <div class="col-md-4" data-aos="fade-up" data-aos-delay="200">
        <a href="https://voice-transcription-system-1.onrender.com/" class="d-block overflow-hidden rounded shadow portfolio-item">
          <img src="/assets/img/trans.png" class="img-fluid" alt="Portfolio project">
        </a>
      </div>

      <div class="col-md-4" data-aos="fade-up" data-aos-delay="300">
        <a href="https://datacap.wuaze.com" class="d-block overflow-hidden rounded shadow portfolio-item">
          <img src="/assets/img/datacap.png" class="img-fluid" alt="Portfolio project">
        </a>
      </div>

    </div>
  </div>
</section>

<!-- Blog Section -->
<section id="blog" class="py-5" data-aos="fade-up">
  <div class="container">

    <!-- Header -->
    <div class="text-center mb-5">
      <h2 class="display-5 fw-bold text-primary text-uppercase">
        I also like to write
      </h2>
      <p class="text-secondary mt-2">
        Check out my latest posts
      </p>
    </div>

    <!-- Blog Grid -->
    <div class="row g-4">

      <!-- Blog 1 -->
      <div class="col-md-4" data-aos="zoom-in" data-aos-delay="100">
        <a href="/blog/post-01" class="text-decoration-none">
          <div class="card blog-card h-100 border-0 shadow-lg">

            <div class="blog-img-wrapper">
              <img src="/assets/img/post-01.png" class="blog-img" alt="Blog 1">
            </div>

            <div class="card-body p-4">
              <h5 class="card-title fw-bold text-primary">
                How to become a frontend developer
              </h5>
              <p class="card-text text-secondary">
                Tips and insights for aspiring frontend developers.
              </p>
            </div>

          </div>
        </a>
      </div>

      <!-- Blog 2 -->
      <div class="col-md-4" data-aos="zoom-in" data-aos-delay="200">
        <a href="/blog/post-02" class="text-decoration-none">
          <div class="card blog-card h-100 border-0 shadow-lg">

            <div class="blog-img-wrapper">
              <img src="/assets/img/post-02.png" class="blog-img" alt="Blog 2">
            </div>

            <div class="card-body p-4">
              <h5 class="card-title fw-bold text-primary">
                My personal productivity system
              </h5>
              <p class="card-text text-secondary">
                How I manage tasks and projects efficiently.
              </p>
            </div>

          </div>
        </a>
      </div>

      <!-- Blog 3 -->
      <div class="col-md-4" data-aos="zoom-in" data-aos-delay="300">
        <a href="/blog/post-03" class="text-decoration-none">
          <div class="card blog-card h-100 border-0 shadow-lg">

            <div class="blog-img-wrapper">
              <img src="/assets/img/post-03.png" class="blog-img" alt="Blog 3">
            </div>

            <div class="card-body p-4">
              <h5 class="card-title fw-bold text-primary">
                Build fast websites with Astro + Netlify
              </h5>
              <p class="card-text text-secondary">
                Build fast, modern websites and deploy them easily using Netlify.
              </p>
            </div>

          </div>
        </a>
      </div>

    </div>
  </div>
</section>

<!-- Contact Section -->
<section id="contact" class="py-5" data-aos="fade-up">
  <div class="container text-center">

    <h2 class="display-5 text-primary fw-bold text-uppercase">Get in touch</h2>
    <p class="text-secondary mt-2">Have any questions or project inquiries? Feel free to reach out.</p>

    <form class="mt-4 mx-auto" style="max-width: 600px;" data-aos="zoom-in" data-aos-delay="200">

      <div class="mb-3">
        <input type="text" class="form-control" placeholder="Name">
      </div>

      <div class="mb-3">
        <input type="email" class="form-control" placeholder="Email">
      </div>

      <div class="mb-3">
        <textarea rows="6" class="form-control" placeholder="Message"></textarea>
      </div>

      <button type="submit" class="btn btn-primary px-4 py-2">Send Message</button>

    </form>
  </div>
</section>

</MainLayout>