---
import MainLayout from "../layouts/MainLayout.astro";

const name = "Daniel Kats";

const profile = {
  country: "Kyambogo University",
  residence: "Kyengera, Wakiso District",
  occupation: "Full Stack Developer / IT Graduate",
  email: "danielkats34@gmail.com",
  phone: "0754 975 422"
};
---

<MainLayout title="About">

<!-- Spacer -->
<div style="height:90px;"></div>

<!-- HERO SECTION -->
<section class="py-5 " data-aos="fade-up">
  <div class="container d-flex flex-column flex-lg-row align-items-center">

    <img src="/assets/img/profile.jpg" alt="Daniel Kats"
      class="rounded-circle shadow border border-white"
      style="width:12rem;height:12rem;"
      data-aos="zoom-in">

    <div class="mt-3 mt-lg-0 ms-lg-4" data-aos="fade-left">
      <h1 class="fw-bold text-primary">Who Is {name}</h1>

      <p class=" mt-3" style="max-width:40rem;">
        I am an Information Technology graduate from {profile.country} passionate about
        building modern web applications and solving real-world problems using technology.
        My focus is on full-stack web development, continuous learning, and contributing
        to innovative teams that create impactful digital solutions.
      </p>

      <p>
        I am always open to collaboration opportunities,
        internships, and technology-driven projects.
      </p>

      <div class="mt-4" data-aos="fade-up" data-aos-delay="200">
        <a href="/assets/cv/daniel-kats-cv.pdf" class="btn btn-primary me-2">Download CV</a>
        <a href="/blog" class="btn btn-primary me-2">Read My Blog</a>
      </div>
    </div>

  </div>
</section>

<!-- TECHNICAL SKILLS -->
<section class="py-5" data-aos="fade-up">
  <div class="container">

    <h2 class="display-6 text-center text-primary fw-bold text-uppercase" data-aos="fade-down">
      Technical Skills
    </h2>

    <div class="row g-4">

      {[
        ["bi-filetype-html","HTML","Semantic and accessible web structure.","text-danger"],
        ["bi-filetype-css","CSS","Responsive styling and modern layouts.","text-primary"],
        ["bi-filetype-js","JavaScript","Interactive and dynamic web applications.","text-warning"],
        ["bi-lightning-charge-fill","React","Modern frontend component-based development.","text-info"],
        ["bi-stars","Astro","Fast static and hybrid websites.","text-dark"],
        ["bi-file-earmark-code","PHP","Backend logic and server-side scripting.","text-indigo"],
        ["bi-cup-hot-fill","Java","Object oriented software development.","text-danger"],
        ["bi-database-fill","MySQL","Database design and SQL queries.","text-primary"],
        ["bi-git","Git","Version control and collaboration.","text-danger"],
        ["bi-cloud-arrow-down-fill","REST APIs","Building and consuming APIs.","text-success"],
        ["bi-bootstrap-fill","Bootstrap","Responsive UI design framework.","text-purple"],
        ["bi-wordpress","WordPress (CMS)","Content management and website building.","text-primary"]
      ].map((skill, i) => (
        <div class="col-md-4 col-lg-3" data-aos="zoom-in" data-aos-delay={i * 100}>
          <div class="card skill-card text-center p-4 h-100">
            <i class={`bi ${skill[0]} display-4 ${skill[3]}`}></i>
            <h5 class="mt-3 fw-bold">{skill[1]}</h5>
            <p class="">{skill[2]}</p>
          </div>
        </div>
      ))}

    </div>
  </div>
</section>

<!-- EXPERIENCE -->
<section class="py-5" data-aos="fade-up">
  <div class="container">

    <h2 class="display-6 text-center text-primary fw-bold text-uppercase" data-aos="fade-down">
      Professional Experience
    </h2>

    <div class="row g-4">

      <div class="col-md-4" data-aos="flip-left">
        <div class="card experience-card text-center p-4 h-100">
          <i class="bi bi-code-slash display-4 text-primary"></i>
          <h5 class="mt-3 fw-bold">Web Lead</h5>
          <p class=" mb-1">Kyambogo University Computing Students Association</p>
          <p class="text-secondary small">2024 - 2025</p>
          <p class="mt-2">
            Led study sessions on modern web technologies and coordinated web development projects.
          </p>
        </div>
      </div>

      <div class="col-md-4" data-aos="flip-up">
        <div class="card experience-card text-center p-4 h-100">
          <i class="bi bi-tools display-4 text-success"></i>
          <h5 class="mt-3 fw-bold">IT Technical Training</h5>
          <p class=" mb-1">Vision Group</p>
          <p class="text-secondary small">June - July 2024</p>
          <p class="mt-2">
            Assisted in maintaining computer systems, installing antivirus software and performing system cleaning.
          </p>
        </div>
      </div>

      <div class="col-md-4" data-aos="flip-right">
        <div class="card experience-card text-center p-4 h-100">
          <i class="bi bi-pc-display display-4 text-warning"></i>
          <h5 class="mt-3 fw-bold">In-house Training</h5>
          <p class=" mb-1">Kyambogo University</p>
          <p class="text-secondary small">June - July 2023</p>
          <p class="mt-2">
            Maintained computers, scanners and printers, installed system software and supported departmental network operations.
          </p>
        </div>
      </div>

    </div>
  </div>
</section>

<!-- EDUCATION -->
<section class="py-5" data-aos="fade-up">
  <div class="container">

    <h2 class="fw-bold text-center mb-5" data-aos="fade-down">Education</h2>

    <div class="row g-4">

      <div class="col-md-4" data-aos="zoom-in-up">
        <div class="card education-card text-center p-4 h-100">
          <i class="bi bi-mortarboard-fill display-4 text-primary"></i>
          <h5 class="mt-3 fw-bold">Kyambogo University</h5>
          <p class="">Bachelor’s Degree in Information Technology and Computing</p>
          <p class="text-secondary small">2022 - 2025</p>
          <button class="btn btn-outline-primary mt-3" data-bs-toggle="modal" data-bs-target="#kyambogoModal">
            View Award
          </button>
        </div>
      </div>

      <div class="col-md-4" data-aos="zoom-in-up" data-aos-delay="100">
        <div class="card education-card text-center p-4 h-100">
          <i class="bi bi-book-fill display-4 text-success"></i>
          <h5 class="mt-3 fw-bold">Royal Giant High School</h5>
          <p class="">Uganda Advanced Certificate of Education (UACE)</p>
          <p class="text-secondary small">2018 - 2019</p>
          <button class="btn btn-outline-success mt-3" data-bs-toggle="modal" data-bs-target="#uaceModal">
            View Award
          </button>
        </div>
      </div>

      <div class="col-md-4" data-aos="zoom-in-up" data-aos-delay="200">
        <div class="card education-card text-center p-4 h-100">
          <i class="bi bi-award-fill display-4 text-warning"></i>
          <h5 class="mt-3 fw-bold">Royal Giant High School</h5>
          <p class="">Uganda Certificate of Education (UCE)</p>
          <p class="text-secondary small">2014 - 2017</p>
          <button class="btn btn-outline-warning mt-3" data-bs-toggle="modal" data-bs-target="#uceModal">
            View Award
          </button>
        </div>
      </div>

    </div>
  </div>
</section>

<!-- MODALS -->
<div class="modal fade" id="kyambogoModal" tabindex="-1">
  <div class="modal-dialog modal-xl modal-dialog-centered">
    <div class="modal-content">
      <div class="modal-header">
        <h5>Kyambogo University Degree</h5>
        <button class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body">
        <iframe src="/assets/awards/kyambogo-degree.pdf" width="100%" height="600"></iframe>
      </div>
    </div>
  </div>
</div>

<div class="modal fade" id="uaceModal" tabindex="-1">
  <div class="modal-dialog modal-xl modal-dialog-centered">
    <div class="modal-content">
      <div class="modal-header">
        <h5>UACE Certificate</h5>
        <button class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body">
        <iframe src="/assets/awards/uace-certificate.pdf" width="100%" height="600"></iframe>
      </div>
    </div>
  </div>
</div>

<div class="modal fade" id="uceModal" tabindex="-1">
  <div class="modal-dialog modal-xl modal-dialog-centered">
    <div class="modal-content">
      <div class="modal-header">
        <h5>UCE Certificate</h5>
        <button class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body">
        <iframe src="/assets/awards/uce-certificate.pdf" width="100%" height="600"></iframe>
      </div>
    </div>
  </div>
</div>

</MainLayout>